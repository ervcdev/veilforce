# ==============================================================================
# VEILFORGE — SMART CONTRACTS ENVIRONMENT VARIABLES TEMPLATE (.env.example)
# ==============================================================================
# Copy this file to '.env' in the same directory and fill in your real keys.
# NEVER commit your actual '.env' file containing private keys to GitHub.

# ─── Somnia Shannon Testnet Configuration ─────────────────────────────────────
SOMNIA_RPC_URL=https://api.infra.testnet.somnia.network/
SOMNIA_WS_URL=wss://api.infra.testnet.somnia.network/ws
SOMNIA_CHAIN_ID=50312

# ─── Deployer Wallet ──────────────────────────────────────────────────────────
# The EOA private key that will execute the deployment script.
# Must hold at least 0.1 STT (Somnia Testnet Tokens) to cover gas fees.
# Note: Format as a 64-character hex string (omit '0x' prefix if standard uint parsing fails).
DEPLOYER_PRIVATE_KEY=your_64_char_deployer_private_key_here

# ─── Autonomous Trading Agents (EOA Public Addresses Only) ────────────────────
# Public addresses for the trading bots. DO NOT paste private keys here.
# The deployment script automatically mints 10,000 mock WETH/USDC to these addresses.
AGENT_1_ADDRESS=0x0000000000000000000000000000000000000001
AGENT_2_ADDRESS=0x0000000000000000000000000000000000000002
AGENT_3_ADDRESS=0x0000000000000000000000000000000000000003

# ─── Contract Verification (Optional) ─────────────────────────────────────────
# Optional placeholder for explorer verification tools. Can be left as 'optional'.
ETHERSCAN_API_KEY=optional

# ─── Post-Deployment Registry (Populated after running forge script) ──────────
# Leave these blank initially. Once 'forge script' executes successfully, 
# copy the live contract addresses from the terminal output and paste them below.
# These values must also be mirrored into 'agent/.env' and 'frontend/.env.local'.
COMMIT_REVEAL_CLOB_ADDRESS=
AGENT_REGISTRY_ADDRESS=
REACTIVITY_ADAPTER_ADDRESS=
TOKEN_A_ADDRESS=
TOKEN_B_ADDRESS=